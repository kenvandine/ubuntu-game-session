#!/bin/bash
# steamos-session - Gamescope wrapper for the SteamOS-like session
# Installed by ubuntu-handheld package to /usr/local/bin/steamos-session

# Connect directly to the host's systemd user D-Bus so Steam can communicate
# with PipeWire/PulseAudio. Spawning a new dbus-launch isolates Steam from audio!
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"

# Environment variables needed for Steam UI under gamescope
export PATH="$PATH:/snap/bin:/usr/games:/usr/local/games"
export XDG_SESSION_DESKTOP=steamos
export XDG_CURRENT_DESKTOP=steamos
export GDK_BACKEND=x11
export SDL_VIDEODRIVER=x11

# Map hardware volume keys to PipeWire via sxhkd running inside Gamescope
mkdir -p "$HOME/.config/sxhkd"
cat > "$HOME/.config/sxhkd/sxhkdrc" << 'KEYBINDINGS'
XF86AudioRaiseVolume
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
KEYBINDINGS

STEAM_FLAGS="-gamepadui"
if [ -f "$HOME/.steam/steam/config/loginusers.vdf" ] || [ -f "$HOME/.local/share/Steam/config/loginusers.vdf" ]; then
    STEAM_FLAGS="-gamepadui -steamos3 -steampal -steamdeck"
fi

exec gamescope -e -f -- bash -c "sxhkd -c \"\$HOME/.config/sxhkd/sxhkdrc\" & steam \$STEAM_FLAGS" >> "$HOME/steamos.log" 2>&1
