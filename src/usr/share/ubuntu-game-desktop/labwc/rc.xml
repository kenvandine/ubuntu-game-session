<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <core>
    <decoration>client</decoration>
    <gap>4</gap>
    <adaptiveSync>yes</adaptiveSync>
    <reuseOutputMode>yes</reuseOutputMode>
  </core>
  <theme>
    <name>Adwaita-dark</name>
    <font place="ActiveWindow">
      <name>Noto Sans</name>
      <size>11</size>
    </font>
  </theme>
  <keyboard>
    <!-- Open app launcher -->
    <keybind key="Super_L">
      <action name="Execute">
        <command>ubuntu-game-launcher</command>
      </action>
    </keybind>
    <keybind key="Super-Space">
      <action name="Execute">
        <command>ubuntu-game-launcher</command>
      </action>
    </keybind>
    <!-- Window management -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="Super-q">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-Shift-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="Super-f">
      <action name="ToggleMaximize"/>
    </keybind>
  </keyboard>
  <mouse>
    <default>
      <!-- Right-click on desktop opens app launcher -->
      <context name="Root">
        <mousebind button="Right" action="Press">
          <action name="Execute">
            <command>ubuntu-game-launcher</command>
          </action>
        </mousebind>
      </context>
    </default>
  </mouse>
</openbox_config>
