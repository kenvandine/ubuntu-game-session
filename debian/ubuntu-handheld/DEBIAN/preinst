#!/bin/bash
# preinst - Runs as root before dpkg unpacks the ubuntu-handheld package
# Responsible for adding the Valve Steam APT signing key so that
# steam-launcher can be installed as a proper apt dependency in postinst.
set -e

case "$1" in
install|upgrade)
    # Add the Valve Steam signing key if not already present
    mkdir -p /usr/share/keyrings
    if [ ! -f /usr/share/keyrings/steam.gpg ]; then
        echo "ubuntu-handheld: fetching Valve Steam APT signing key..."
        curl -sL https://repo.steampowered.com/steam/archive/stable/steam.gpg \
            -o /usr/share/keyrings/steam.gpg
    fi

    # Enable i386 architecture (required by steam-launcher)
    dpkg --add-architecture i386

    # Update apt so steam-launcher (and i386 packages) are resolvable
    apt-get update -q
    ;;
esac

exit 0
