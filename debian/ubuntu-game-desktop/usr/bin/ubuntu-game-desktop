#!/bin/bash
# ubuntu-game-desktop - Lightweight Wayland gaming desktop session
# Installed by ubuntu-game-desktop package to /usr/bin/ubuntu-game-desktop
#
# Uses labwc as compositor, waybar for panel, wofi for .desktop launcher.
# Games are launched via per-game gamescope wrappers (not a gamescope session).

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"

export XDG_SESSION_DESKTOP=ubuntu-game-desktop
export XDG_CURRENT_DESKTOP=ubuntu-game-desktop

export PATH="$PATH:/snap/bin:/usr/games:/usr/local/games"

# Prepend our config dir so labwc, waybar, and wofi pick up the session
# defaults. User configs in ~/.config/{labwc,waybar,wofi} take priority.
export XDG_CONFIG_DIRS="/usr/share/ubuntu-game-desktop${XDG_CONFIG_DIRS:+:$XDG_CONFIG_DIRS}"

exec labwc >> "$HOME/ubuntu-game-desktop.log" 2>&1
