#!/bin/bash
# Power menu using wofi — shown when the panel power button is clicked.
# Presents Shut Down / Reboot / Log Out options and confirms before acting.

CHOICE=$(printf "Shut Down\nReboot\nLog Out" \
    | wofi --dmenu \
           --prompt "Power" \
           --lines 3 \
           --width 220 \
           --height 140 \
           --hide-scroll \
           --no-actions \
           --insensitive)

case "$CHOICE" in
    "Shut Down") systemctl poweroff ;;
    "Reboot")    systemctl reboot   ;;
    "Log Out")   labwc --exit       ;;
esac
