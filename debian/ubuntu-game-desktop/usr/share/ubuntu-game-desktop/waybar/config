{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "modules-left": ["custom/launcher", "wlr/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["network", "battery", "custom/logout", "custom/reboot", "custom/shutdown"],

    "custom/launcher": {
        "format": "🎮",
        "on-click": "wofi --show drun",
        "tooltip": "Launch application (or right-click desktop / press Super)"
    },

    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "on-click": "activate",
        "on-click-right": "close",
        "tooltip-format": "{title}"
    },

    "clock": {
        "format": "{:%H:%M  %a %b %-d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "network": {
        "format-wifi": "  {signalStrength}% {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰖪 Disconnected",
        "format-disabled": "",
        "on-click": "nm-connection-editor",
        "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nFrequency: {frequency} GHz\nIP: {ipaddr}",
        "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}",
        "tooltip-format-disconnected": "No network connection"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": " {capacity}%",
        "format-full": " Full",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo}\nPower draw: {power:.1f}W"
    },

    "custom/logout": {
        "format": "󰍃",
        "on-click": "labwc --exit",
        "tooltip": "Log out"
    },

    "custom/reboot": {
        "format": "󰜉",
        "on-click": "systemctl reboot",
        "tooltip": "Reboot"
    },

    "custom/shutdown": {
        "format": "󰐥",
        "on-click": "systemctl poweroff",
        "tooltip": "Shut down"
    }
}
